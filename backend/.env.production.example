# =============================================================================
# RENDER PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy these to Render Dashboard → Environment Variables
# DO NOT commit actual values to Git!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - LLM Provider Configuration
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your_actual_google_api_key_here
# OPENAI_API_KEY=your_openai_key_here  # Only if using OpenAI

# -----------------------------------------------------------------------------
# REQUIRED - Application Settings
# -----------------------------------------------------------------------------
APP_NAME=LegalRAG AI Chatbot
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# REQUIRED - CORS Settings
# -----------------------------------------------------------------------------
# IMPORTANT: Include your Vercel frontend URL
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# REQUIRED - MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=chat_companion

# -----------------------------------------------------------------------------
# REQUIRED - Storage Configuration (Render Persistent Disk)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=/data/chromadb
UPLOADS_DIR=/data/uploads

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,txt

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=4
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Hybrid Search Configuration
# -----------------------------------------------------------------------------
USE_HYBRID_SEARCH=True
USE_RERANKING=True
RETRIEVAL_K=20
SEMANTIC_WEIGHT=0.5
BM25_WEIGHT=0.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -----------------------------------------------------------------------------
# Query Enhancement Configuration
# -----------------------------------------------------------------------------
USE_QUERY_ENHANCEMENT=True
EXPAND_QUERIES=True

# -----------------------------------------------------------------------------
# Context Compression Configuration
# -----------------------------------------------------------------------------
USE_CONTEXT_COMPRESSION=True
RELEVANCE_THRESHOLD=0.3
MAX_SENTENCES_PER_DOC=10
MAX_CONTEXT_TOKENS=2000

# -----------------------------------------------------------------------------
# LLM Settings
# -----------------------------------------------------------------------------
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# -----------------------------------------------------------------------------
# REQUIRED - JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-random-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# REQUIRED (if using OAuth) - Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# REQUIRED (if using email) - Email Configuration
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=LexiAI

# -----------------------------------------------------------------------------
# REQUIRED - Password Reset Configuration
# -----------------------------------------------------------------------------
RESET_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL=https://your-vercel-app.vercel.app

# =============================================================================
# DEPLOYMENT NOTES:
# =============================================================================
# 1. Set all these variables in Render Dashboard → Environment tab
# 2. Use "sync: false" in render.yaml for secrets
# 3. Never commit actual secrets to Git
# 4. Generate strong JWT_SECRET_KEY (min 32 random characters)
# 5. Use MongoDB Atlas connection string with correct credentials
# 6. Add your Vercel URL to CORS_ORIGINS
# 7. Persistent disk must be mounted at /data
# =============================================================================
