# =============================================================================
# LegalRAG AI Chatbot - Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Choose your LLM provider: "openai" or "gemini"
# Using Gemini as the primary provider
LLM_PROVIDER=gemini

# -----------------------------------------------------------------------------
# Google Gemini Configuration (PRIMARY)
# -----------------------------------------------------------------------------
# Get your API key from: https://makersuite.google.com/app/apikey
# Or from: https://aistudio.google.com/app/apikey
# Model used: gemini-pro (free tier available)
GOOGLE_API_KEY=your_google_api_key_here

# -----------------------------------------------------------------------------
# OpenAI Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# Only needed if you want to switch to OpenAI
# Get your API key from: https://platform.openai.com/api-keys
# Models available: gpt-3.5-turbo (faster, cheaper) or gpt-4 (better quality)
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=LegalRAG AI Chatbot
APP_VERSION=1.0.0

# Debug mode: True for development, False for production
DEBUG=True

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Host: 0.0.0.0 allows external connections, 127.0.0.1 for localhost only
HOST=0.0.0.0

# Port: Default 8000, change if port is already in use
PORT=8000

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (frontend URLs)
# For development with React (Vite): http://localhost:5173
# For development with React (CRA): http://localhost:3000
# For production: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
# Maximum file size in megabytes
# Recommended: 10MB for most documents, increase for large PDFs
MAX_FILE_SIZE_MB=10

# Allowed file extensions (comma-separated, no dots)
# Supported: pdf, docx, txt
ALLOWED_EXTENSIONS=pdf,docx,txt

# -----------------------------------------------------------------------------
# RAG Configuration - Text Chunking
# -----------------------------------------------------------------------------
# Chunk size: Number of characters per chunk
# Smaller chunks (500-800): More precise but may lose context
# Medium chunks (1000-1500): Balanced (RECOMMENDED for legal docs)
# Larger chunks (2000+): More context but less precise
CHUNK_SIZE=1000

# Chunk overlap: Number of overlapping characters between chunks
# Prevents information loss at chunk boundaries
# Recommended: 15-20% of chunk size
# For 1000 char chunks: 150-200 overlap
CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# RAG Configuration - Retrieval
# -----------------------------------------------------------------------------
# Top K: Number of most relevant chunks to retrieve
# Too low (1-2): May miss important context
# Balanced (3-5): RECOMMENDED for most use cases
# Too high (10+): More context but more noise
TOP_K_RETRIEVAL=4

# -----------------------------------------------------------------------------
# RAG Configuration - Embeddings
# -----------------------------------------------------------------------------
# Embedding model from Sentence Transformers
# Options:
# - all-MiniLM-L6-v2: Fast, 384 dimensions (RECOMMENDED)
# - all-mpnet-base-v2: More accurate, 768 dimensions, slower
# - all-MiniLM-L12-v2: Balanced option
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# LLM Settings
# -----------------------------------------------------------------------------
# Temperature: Controls randomness of responses (0.0 to 1.0)
# 0.0: Deterministic, focused (RECOMMENDED for factual Q&A)
# 0.1-0.3: Slightly varied but consistent (good for legal)
# 0.5-0.7: Balanced creativity
# 1.0: Maximum creativity (not recommended for factual)
LLM_TEMPERATURE=0.1

# Max tokens: Maximum length of generated response
# Shorter (200-300): Concise answers
# Medium (500-800): Detailed answers (RECOMMENDED)
# Longer (1000+): Very detailed, may be verbose
LLM_MAX_TOKENS=500

# =============================================================================
# Advanced Settings (Optional - Use defaults unless you know what you're doing)
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Database connection (for future PostgreSQL integration)
# DATABASE_URL=postgresql://user:password@localhost:5432/legalrag

# Redis connection (for caching)
# REDIS_URL=redis://localhost:6379/0

# Sentry DSN (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit this file with real API keys to version control
# 2. Add .env to .gitignore (already done)
# 3. For production, use environment variables or secrets management
# 4. Restart the application after changing these values
# 5. See README.md for detailed configuration guide
# =============================================================================
