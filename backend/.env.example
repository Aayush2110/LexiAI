# LLM Provider Configuration
# Choose either OpenAI or Gemini by setting LLM_PROVIDER
LLM_PROVIDER=gemini  # Options: "openai" or "gemini"

# Google Gemini Configuration (PRIMARY)
GOOGLE_API_KEY=AIzaSyAZ6CZTnP_8Bb6cs8KO0RDQQOWU0liK5aQ1

# OpenAI Configuration (OPTIONAL - only if you want to use OpenAI instead)
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_NAME=LegalRAG AI Chatbot
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (Frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=chat_companion

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chromadb

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,txt

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=4
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500
