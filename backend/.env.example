# LLM Provider Configuration
# Choose either OpenAI or Gemini by setting LLM_PROVIDER
LLM_PROVIDER=gemini  # Options: "openai" or "gemini"

# Google Gemini Configuration (PRIMARY)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI Configuration (OPTIONAL - only if you want to use OpenAI instead)
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_NAME=LegalRAG AI Chatbot
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (Frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-vercel-app.vercel.app

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=chat_companion

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chromadb

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,txt

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=4
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Hybrid Search Configuration (Enhanced RAG)
USE_HYBRID_SEARCH=True  # Enable hybrid search (semantic + BM25 + reranking)
USE_RERANKING=True  # Enable cross-encoder reranking
RETRIEVAL_K=20  # Number of documents to retrieve before reranking
SEMANTIC_WEIGHT=0.5  # Weight for semantic search (0-1)
BM25_WEIGHT=0.5  # Weight for BM25 keyword search (0-1)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Query Enhancement Configuration
USE_QUERY_ENHANCEMENT=True  # Enable query preprocessing and expansion
EXPAND_QUERIES=True  # Generate query variations for better recall

# Context Compression Configuration
USE_CONTEXT_COMPRESSION=True  # Enable context compression
RELEVANCE_THRESHOLD=0.3  # Minimum relevance score for sentences (0-1)
MAX_SENTENCES_PER_DOC=10  # Maximum sentences per document
MAX_CONTEXT_TOKENS=2000  # Maximum tokens for LLM context

# LLM Settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth (Get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Configuration (Gmail SMTP for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=LexiAI

# Password Reset
RESET_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL=http://localhost:5173
